! ============================================================
! Макрос: Консольная балка / плоская КЭ-постановка
! Элемент: PLANE182 (плоское напряжённое состояние с толщиной)
! Левая грань защемлена; на правую грань приложена полная
! вертикальная сила force, распределённая между узлами торца.
! Результаты -> cantilever_result.txt (фиксированный формат).
! Параметры len/height/thk/force подставляются скриптом 02_run_ansys_batch.py
! ============================================================

/CLEAR,NOSTART
/PREP7

! ------------------------------------------------------------
! 1. ПАРАМЕТРЫ ЗАДАЧИ (эти 4 строки заменяет Python для каждой DOE-точки)
! ------------------------------------------------------------
len    = 10.0
height = 1.0
thk    = 0.1
force  = 1000.0

! Материал (сталь)
exx    = 2.1e11
nuxy   = 0.3

! Параметр сетки
esize_val = height/6

! Геометрические характеристики
area   = len*height
volume = len*height*thk

! ------------------------------------------------------------
! 2. ТИП ЭЛЕМЕНТА И МАТЕРИАЛ
! ------------------------------------------------------------
ET,1,PLANE182
KEYOPT,1,1,0
KEYOPT,1,3,3            ! плоское напряжённое состояние с толщиной
R,1,thk
MP,EX,1,exx
MP,PRXY,1,nuxy

! ------------------------------------------------------------
! 3. ГЕОМЕТРИЯ
! ------------------------------------------------------------
RECTNG,0,len,0,height

! ------------------------------------------------------------
! 4. СЕТКА
! ------------------------------------------------------------
ESIZE,esize_val
AMESH,ALL

! ------------------------------------------------------------
! 5. ГРАНИЧНЫЕ УСЛОВИЯ (защемление левой грани)
! ------------------------------------------------------------
NSEL,S,LOC,X,0
D,ALL,UX,0
D,ALL,UY,0
ALLSEL,ALL

! ------------------------------------------------------------
! 6. НАГРУЗКА (полная сила распределена по узлам правого торца)
! ------------------------------------------------------------
NSEL,S,LOC,X,len
*GET,n_right,NODE,0,COUNT
f_node = -force/n_right
F,ALL,FY,f_node
ALLSEL,ALL

! ------------------------------------------------------------
! 7. РЕШЕНИЕ
! ------------------------------------------------------------
FINISH
/SOLU
ANTYPE,STATIC
SOLVE
FINISH

! ------------------------------------------------------------
! 8. ПОСТПРОЦЕССИНГ
! ------------------------------------------------------------
/POST1
SET,LAST

! Контрольная точка на правом торце, ближайшая к середине высоты
NSEL,S,LOC,X,len
NSEL,R,LOC,Y,height/2
*GET,node_tip,NODE,0,NUM,MIN
ALLSEL,ALL
*GET,uy_tip,NODE,node_tip,U,Y

! Максимальное вертикальное перемещение (по модулю)
NSORT,U,Y
*GET,uy_min,SORT,0,MIN
ALLSEL,ALL
uy_max = ABS(uy_min)

! Максимальное суммарное перемещение
NSORT,U,SUM
*GET,u_sum_max,SORT,0,MAX
ALLSEL,ALL

! Максимальное эквивалентное напряжение по Мизесу
NSORT,S,EQV
*GET,sig_max_plane,SORT,0,MAX
ALLSEL,ALL

! ------------------------------------------------------------
! 9. ВИЗУАЛИЗАЦИЯ (для ручного экспорта картинок UY и SEQV)
! ------------------------------------------------------------
/ESHAPE,1
/REPLOT
PLNSOL,U,Y
PLNSOL,S,EQV

! ------------------------------------------------------------
! 10. ЗАПИСЬ РЕЗУЛЬТАТОВ
! ------------------------------------------------------------
*CFOPEN,cantilever_result,txt
*VWRITE,len,height,thk,force,uy_tip,uy_max,u_sum_max,sig_max_plane,area,volume
(E16.8,1X,E16.8,1X,E16.8,1X,E16.8,1X,E16.8,1X,E16.8,1X,E16.8,1X,E16.8,1X,E16.8,1X,E16.8)
*CFCLOSE

! ------------------------------------------------------------
! 11. ВЫВОД В ОКНО ANSYS
! ------------------------------------------------------------
*STATUS,len
*STATUS,height
*STATUS,thk
*STATUS,force
*STATUS,uy_tip
*STATUS,uy_max
*STATUS,u_sum_max
*STATUS,sig_max_plane
*STATUS,area
*STATUS,volume

FINISH
